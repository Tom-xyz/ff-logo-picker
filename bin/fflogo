#!/usr/bin/env bash
# fflogo — interactive picker for fastfetch's built-in ASCII logos
#
# Source:  https://github.com/tom-xyz/ff-logo-picker
# License: MIT

set -euo pipefail

VERSION="0.1.1"
CONFIG="${FFLOGO_CONFIG:-$HOME/.config/fastfetch/config.jsonc}"

usage() {
  cat <<'EOF'
fflogo — interactive picker for fastfetch ASCII logos

USAGE
  fflogo [OPTIONS]

OPTIONS
  -p, --print       Print the chosen logo name; do not modify config
  -r, --random      Skip the picker; pick a random logo and apply
  -h, --help        Show this help
  -V, --version     Show version

ENVIRONMENT
  FFLOGO_CONFIG     Override fastfetch config path
                    (default: ~/.config/fastfetch/config.jsonc)

Source: https://github.com/tom-xyz/ff-logo-picker
EOF
}

err() { printf 'fflogo: %s\n' "$*" >&2; }

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    err "$1 not found. install with: brew install $1"
    exit 1
  fi
}

# Pulls the canonical name of every built-in logo from the installed fastfetch.
# Output format of `fastfetch --list-logos`:
#   1)  "Adélie" "Adelie"
#   2)  "aerOS"
# Pick the first quoted token per line.
list_logos() {
  fastfetch --list-logos 2>/dev/null \
    | sed -nE 's/^[[:space:]]*[0-9]+\)[[:space:]]*"([^"]+)".*/\1/p'
}

# Create a minimal fastfetch config if the user has none.
ensure_config() {
  [[ -f "$CONFIG" ]] && return
  mkdir -p "$(dirname "$CONFIG")"
  cat >"$CONFIG" <<'JSON'
{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "Apple",
    "type": "builtin",
    "padding": { "right": 8 }
  },
  "modules": [
    "title",
    "separator",
    { "type": "os",     "key": " os",     "keyColor": "cyan" },
    { "type": "host",   "key": " host",   "keyColor": "cyan" },
    { "type": "kernel", "key": " kernel", "keyColor": "cyan" },
    { "type": "uptime", "key": " uptime", "keyColor": "cyan" },
    { "type": "shell",  "key": " shell",  "keyColor": "cyan" },
    { "type": "cpu",    "key": " cpu",    "keyColor": "cyan" },
    { "type": "memory", "key": " memory", "keyColor": "cyan" },
    { "type": "disk",   "key": " disk",   "keyColor": "cyan", "folders": "/" }
  ]
}
JSON
}

# Rewrite "source" and "type" in the existing config — but ONLY inside the
# top-level "logo": { ... } block. A naïve global sed would clobber the
# "type" field of every module too. We use awk to track the in-logo state
# from the "logo": { line until the next top-level key ("modules", "display",
# "general", etc.) and only substitute within that range.
apply_logo() {
  local name="$1"
  ensure_config
  if ! grep -q '"source"' "$CONFIG"; then
    err "no \"source\" field found in $CONFIG; refusing to modify"
    exit 1
  fi
  local tmp
  tmp=$(mktemp "${TMPDIR:-/tmp}/fflogo.XXXXXX")
  awk -v src="$name" '
    /^[[:space:]]*"(modules|display|general|modulesPreset)":/ { in_logo = 0 }
    in_logo && /"source":/ {
      sub(/"source":[[:space:]]*"[^"]*"/, "\"source\": \"" src "\"")
    }
    in_logo && /"type":/ {
      sub(/"type":[[:space:]]*"[^"]*"/, "\"type\": \"builtin\"")
    }
    /^[[:space:]]*"logo":[[:space:]]*\{/ { in_logo = 1 }
    { print }
  ' "$CONFIG" > "$tmp" && mv "$tmp" "$CONFIG"
}

pick_with_fzf() {
  # `tab` toggles preview between color (default) and mono (ANSI stripped).
  # State lives in a marker file unique to this fflogo invocation.
  # `--pipe false` forces fastfetch to emit colors even when piped — fzf's
  # preview pane is not a TTY, so without this fastfetch strips colors.
  # Using printf for the ESC byte keeps the sed pattern POSIX-compatible
  # so the preview works regardless of the user's $SHELL.
  local esc marker render preview_cmd toggle_cmd header_cmd hdr_color hdr_mono
  esc=$(printf '\033')
  marker="${TMPDIR:-/tmp}/.fflogo-mono-$$"
  trap 'rm -f "$marker"' RETURN
  render='fastfetch --logo {} --logo-type builtin --pipe false 2>/dev/null'
  preview_cmd="if [ -f '$marker' ]; then $render | sed 's/${esc}\\[[0-9;]*m//g'; else $render; fi"
  toggle_cmd="if [ -f '$marker' ]; then rm -f '$marker'; else touch '$marker'; fi"
  hdr_color='ENTER apply  ·  ESC cancel  ·  TAB toggle  ·  ● color'
  hdr_mono='ENTER apply  ·  ESC cancel  ·  TAB toggle  ·  ○ mono'
  header_cmd="if [ -f '$marker' ]; then printf '%s' '$hdr_mono'; else printf '%s' '$hdr_color'; fi"

  list_logos \
    | fzf --ansi \
          --preview "$preview_cmd" \
          --preview-window=right:65%:wrap \
          --bind "tab:execute-silent($toggle_cmd)+refresh-preview+transform-header($header_cmd)" \
          --header "$hdr_color"
}

main() {
  local mode=interactive
  while (($#)); do
    case "$1" in
      -p|--print)   mode=print ;;
      -r|--random)  mode=random ;;
      -h|--help)    usage; exit 0 ;;
      -V|--version) printf 'fflogo %s\n' "$VERSION"; exit 0 ;;
      *) err "unknown option: $1"; usage >&2; exit 1 ;;
    esac
    shift
  done

  require_cmd fastfetch
  [[ "$mode" != random ]] && require_cmd fzf

  local picked=""
  case "$mode" in
    interactive|print)
      picked=$(pick_with_fzf) || true
      ;;
    random)
      picked=$(list_logos \
        | awk 'BEGIN{srand()} {a[NR]=$0} END{if(NR>0)print a[int(rand()*NR)+1]}')
      ;;
  esac

  [[ -z "$picked" ]] && exit 0

  if [[ "$mode" == print ]]; then
    printf '%s\n' "$picked"
  else
    apply_logo "$picked"
    err "applied: $picked"
    fastfetch
  fi
}

main "$@"
